# Dominio público bajo el que se sirve la app (Caddy obtiene TLS para él).
# Para probar en local: usa `localhost` y exponer puerto 80 (sin TLS).
DOMAIN=recall.example.com

# Secret usado para firmar la cookie de sesión.
# Genera uno con: openssl rand -hex 32
COOKIE_SECRET=replace_me_with_openssl_rand_hex_32

# (Opcional) Primer invite code que se siembra en la DB cuando no hay usuarios.
# Lo usa quien va a registrarse como admin la primera vez.
# Después de ese primer uso queda inutilizado.
BOOTSTRAP_INVITE=FIRSTRUN
